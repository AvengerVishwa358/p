def show_board(board):
    print("+-------+-------+-------+")
    for i in range(9):
        print("|", end=" ")
        for j in range(9):
            val = board[i][j] if board[i][j] != 0 else "."
            print(val, end=" ")
            if (j + 1) % 3 == 0:
                print("|", end=" ")
        print()
        if (i + 1) % 3 == 0:
            print("+-------+-------+-------+")

def possible(board, r, c):
    if board[r][c] != 0:
        return []
nums = set(range(1, 10))

    nums -= set(board[r])                     # row
    nums -= {board[i][c] for i in range(9)}   # column
    # box
    br, bc = (r//3)*3, (c//3)*3
    nums -= {board[i][j] for i in range(br, br+3) for j in range(bc, bc+3)}  
return list(nums)

def solve_logic(board):
    changed = True
    while changed:
        changed = False
        for r in range(9):
            for c in range(9):
                if board[r][c] == 0:
                    p = possible(board, r, c)
                    if len(p) == 1:
                        board[r][c] = p[0]
                        changed = True
    return board

