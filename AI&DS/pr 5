def is_safe(board, row, col, n):
    for i in range(n):
        if board[i] != -1 and i != row:
            if board[i] == col:
                return False
            if abs(i - row) == abs(board[i] - col):
                return False
    return True

def solve_iterative(n, fixed_row, fixed_col):
    board = [-1] * n
    board[fixed_row] = fixed_col
    col_choices = [0] * n 
    row = 0
    while row < n:
        if row == fixed_row:
            row += 1
            continue
        found = False
        for col in range(col_choices[row], n):
            if is_safe(board, row, col, n):
                board[row] = col
                col_choices[row] = col + 1
                found = True
                break
        if found:
            row += 1
        else:
            col_choices[row] = 0
            board[row] = -1
            row -= 1
            while row == fixed_row:
                row -= 1
            
            if row < 0:
                return None
                
    return board
def print_board(board, n):
    for i in range(n):
        for j in range(n):
            if board[i] == j:
                print("Q", end=" ")
            else:
                print(".", end=" ")
        print()
